{
  "name": "lyra",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @lyra/db",
    "db:studio": "turbo run db:studio -F @lyra/db",
    "db:generate": "turbo run db:generate -F @lyra/db",
    "db:migrate": "turbo run db:migrate -F @lyra/db",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@lyra/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@lyra/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "^6"
  },
  "packageManager": "pnpm@10.33.4"
}
